# parameters - 'source nkpp-env' to consume these.

# Cluster configuration
export CLUSTER_NAME="nkp-xxx-cluster"

# Kubernetes API Server VIP (must be on same subnet as your nodes)
export CLUSTER_VIP="xxx.yyy.zzz.70"

# Network interface name (find using 'ip address' on control plane nodes)
export CLUSTER_VIP_ETH_INTERFACE="ens3"
#The network interface name (ens3 in this example) can vary depending on the OS and platform; use the 'ip address' command on your nodes to find the correct name

# Control plane node IP addresses (minimum 3 for production)
export CONTROL_PLANE_1_ADDRESS="xxx.yyy.zzz.51"
export CONTROL_PLANE_2_ADDRESS="xxx.yyy.zzz.52"
export CONTROL_PLANE_3_ADDRESS="xxx.yyy.zzz.53"

# Initial worker node IP addresses
export WORKER_1_ADDRESS="xxx.yyy.zzz.54"
export WORKER_2_ADDRESS="xxx.yyy.zzz.55"
export WORKER_3_ADDRESS="xxx.yyy.zzz.56"
export WORKER_4_ADDRESS="xxx.yyy.zzz.57"

# Nodepool worker node IP addresses
export GPU_WORKER_COUNT=1
export GPU_WORKER_1_ADDRESS="xxx.yyy.zzz.58"
export GPU_WORKER_2_ADDRESS="xxx.yyy.zzz.59"
export GPU_WORKER_3_ADDRESS="xxx.yyy.zzz.60"
export GPU_WORKER_4_ADDRESS="xxx.yyy.zzz.61"
export GPU_WORKER_5_ADDRESS="xxx.yyy.zzz.62"
export GPU_WORKER_6_ADDRESS="xxx.yyy.zzz.63"

# Set Nvidia GPU driver version
# version 580
# export NVIDIA_URL="https://download.nvidia.com/XFree86/Linux-x86_64/580.126.18/NVIDIA-Linux-x86_64-580.126.18.run"
# version 535
export NVIDIA_URL="https://download.nvidia.com/XFree86/Linux-x86_64/535.261.03/NVIDIA-Linux-x86_64-535.261.03.run"


# SSH configuration for node access
export SSH_USER="konvoy"
export SSH_PRIVATE_KEY_FILE="/home/nutanix/.ssh/id_rsa"
export SSH_PRIVATE_KEY_SECRET_NAME=${CLUSTER_NAME}-ssh-key


# uncomment the below parameters whif you want to use a registry mirror
# if you're using 2.16 or later, leave these lines commented to use the built-in private reagistry

# export REGISTRY_MIRROR_URL=registry.nutanixdemo.com/nkpairgap                 # Required on Nutanix HPOC or internet connected deployments to avoid docker rate limiting
# export REGISTRY_MIRROR_USERNAME=                                # Required on internet connected deployments to avoid docker rate limiting
# export REGISTRY_MIRROR_PASSWORD=                                # Required on internet connected deployments to avoid docker rate limiting
# export REGISTRY_MIRROR_CA=registry-ca_cert.pem
# export AIRGAP_REGISTRY_MIRROR_URL=registry.nutanixdemo.com/nkpairgap              # Required on Nutanix HPOC or internet connected deployments to avoid docker rate limiting
# export AIRGAP_REGISTRY_MIRROR_USERNAME='harbor user'                 # Required on Nutanix HPOC or internet connected deployments to avoid docker rate limiting
# export AIRGAP_REGISTRY_MIRROR_PASSWORD='harbor password'                 # Required on Nutanix HPOC or internet connected deployments to avoid docker rate limiting

# skip preflight checks
# export SKIP_PREFLIGHT_CHECKS=Registry        # Skip preflight checks. Provide "all" to skip all checks, or a comma-separated list of check names. (default [])


# Other Options

# Load Balancer range
export LB_IP_RANGE=10.38.207.159-10.38.207.160                    # Load balancer IP pool - Ex: 10.42.236.204-10.42.236.204

export NTPSERVERS=""      # A comma-separated list of NTP servers to configure on all nodes. Each entry must be a fully qualified domain name (FQDN) or an IP address (IPv4 or IPv6). This list overrides any default NTP settings preconfigured in the machine image. (default [])

# k8s internal networks
export POD_CIDR=10.95.0.0/16
export SERVICE_CIDR=10.96.0.0/12

# Nutanix CSI parameters

export NUTANIX_USER=nkp-admin                                # Prism Central username for nkp clusterapi integration - avoid admin if possible
export NUTANIX_PASSWORD='supersecretpassword'                   # Keep the password enclosed between single quotes - Ex: 'password'
export NUTANIX_ENDPOINT=10.38.207.7                             # Prism Central IP address or FQDN without https://
export NUTANIX_PORT=9440                                        # Prism Central port (default: 9440)
export NUTANIX_PRISM_ELEMENT_CLUSTER_NAME=PHX-POC207            # Prism Element cluster name - Ex: PHX-POC207
export NUTANIX_STORAGE_CONTAINER_NAME=SelfServiceContainer      # Change to your preferred Prism storage container
export CSI_HYPERVISOR_ATTACHED=false                             # Optional, used to enable hypervisor attached volumes for the cluster
